# Required: primary Gemini key or comma-separated list for rotation
GEMINI_API_KEY=your_gemini_key_here
# Optional: use a comma-separated list for rotating multiple Gemini keys
# GEMINI_API_KEYS=key1,key2,key3

# Optional backup models
# ANTHROPIC_API_KEY=your_anthropic_key_here
# GLM_API_KEY=your_glm_api_key_here

# Optional local AI endpoint for offline/fallback testing
# LOCAL_AI_URL=http://localhost:8000/chat
